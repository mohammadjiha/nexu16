# Uncomment this line to define a global platform for your project
platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Disable experimental Swift Package Manager integration (causes build failures
# with flutter_native_splash and alarm on some Flutter versions).
ENV['SWIFT_PACKAGE_MANAGER_ENABLED'] = 'false'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig and running flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force all pods to iOS 15.5 minimum
      current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f
      if current < 15.5
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
      end
      # Force disable code signing for all Pods
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings.delete('CODE_SIGN_ENTITLEMENTS')
      config.build_settings.delete('CODE_SIGN_IDENTITY')
      config.build_settings.delete('DEVELOPMENT_TEAM')
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end

  # Force disable code signing for the main Runner project
  require 'xcodeproj'
  project_path = 'Runner.xcodeproj'
  if File.exist?(project_path)
    project = Xcodeproj::Project.open(project_path)
    project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGN_STYLE'] = 'Manual'
        config.build_settings['CODE_SIGN_IDENTITY'] = ''
        config.build_settings['CODE_SIGN_IDENTITY[sdk=iphoneos*]'] = ''
        config.build_settings.delete('DEVELOPMENT_TEAM')
        config.build_settings.delete('PROVISIONING_PROFILE_SPECIFIER')
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
    project.save
    puts "✅ Stripped code signing from Runner.xcodeproj"
  end

  # ── Patch camera_avfoundation: fix AVCaptureSession API removed in newer SDKs ──
  # DefaultCamera.swift uses AVCaptureSession.wasInterruptedNotification and
  # runtimeErrorNotification which are no longer accessible as class members
  # in some SDK/Swift combos. Replace with NSNotification.Name equivalents.
  Dir.glob(File.join(installer.sandbox.root, '**', 'DefaultCamera.swift')).each do |swift_file|
    content = File.read(swift_file)
    patched = content
      .gsub('AVCaptureSession.wasInterruptedNotification',
            'NSNotification.Name("AVCaptureSessionWasInterruptedNotification")')
      .gsub('AVCaptureSession.runtimeErrorNotification',
            'NSNotification.Name("AVCaptureSessionRuntimeErrorNotification")')
    if content != patched
      File.write(swift_file, patched)
      puts "✅ Patched camera_avfoundation DefaultCamera.swift"
    end
  end
end
