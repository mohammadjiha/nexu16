#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase — config files (safe to commit; security enforced by Firestore rules)
# lib/firebase_options.dart
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist

# Environment / secrets
*.env
.env.*
secrets.dart

# Firebase service account keys — NEVER commit these
serviceAccountKey*.json
*serviceAccount*.json
*serviceAccountKey*

# Admin setup scripts — contain hardcoded credentials
setup_admin.js
setup_jama.js
scripts/

# Node modules — never commit these
node_modules/
functions/node_modules/

