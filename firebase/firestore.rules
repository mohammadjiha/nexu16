rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ── Rate-limiting helpers ────────────────────────────────────────────────
    //
    // Strategy: compare request.time (server-side, tamper-proof) against a
    // `lastWriteAt` / `lastMessageAt` / `lastPostAt` timestamp stored in a
    // parent or sibling document that is updated atomically with every write.
    //
    // Client code must include FieldValue.serverTimestamp() in every write for
    // the guarded fields; the rules then enforce the minimum gap.

    /// True if the chat room's last message was written more than [secs] seconds
    /// ago (or if no previous message exists). Guards /chats/{id}/messages.
    function chatMessageAllowed(chatId, secs) {
      let chatDoc = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return !exists(/databases/$(database)/documents/chats/$(chatId)) ||
             !('lastMessageAt' in chatDoc) ||
             chatDoc.lastMessageAt == null ||
             request.time > chatDoc.lastMessageAt + duration.value(secs, 's');
    }

    function chatParticipant(chatId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/chats/$(chatId)) &&
        request.auth.uid in
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function chatParticipantAfter(chatId) {
      return signedIn() &&
        request.auth.uid in
          getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function chatNotificationAllowed(userId) {
      return signedIn() &&
        request.resource.data.type == 'chat' &&
        request.resource.data.chatId is string &&
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in
          getAfter(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants &&
        userId in
          getAfter(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants;
    }

    /// True if the user's last community post was more than [secs] seconds ago.
    /// Requires users/{uid}.lastPostAt to be updated on every post create.
    function postCooldownPassed(uid, secs) {
      let userData = get(/databases/$(database)/documents/users/$(uid)).data;
      return !('lastPostAt' in userData) ||
             userData.lastPostAt == null ||
             request.time > userData.lastPostAt + duration.value(secs, 's');
    }

    /// True if the user's last notification write was more than [secs] ago.
    /// Guards coach → player notification spam.
    function notifCooldownPassed(targetUid, secs) {
      let userData = get(/databases/$(database)/documents/users/$(targetUid)).data;
      return !('lastNotifAt' in userData) ||
             userData.lastNotifAt == null ||
             request.time > userData.lastNotifAt + duration.value(secs, 's');
    }

    /// True if the authenticated user is not creating more than [maxSize] bytes
    /// of data (rough guard against document-size abuse).
    function withinSizeLimit(maxSize) {
      return request.resource.data.size() <= maxSize;
    }

    function currentUserGymId() {
      return currentUser().gymId;
    }

    function currentUserRole() {
      return currentUser().role;
    }

    function hasVerifiedEmail() {
      return signedIn() &&
        request.auth.token.email is string &&
        request.auth.token.email_verified == true;
    }

    function authEmailKey() {
      return request.auth.token.email.lower();
    }

    function isInvitedToGym(gymId) {
      return hasVerifiedEmail() &&
        gymId is string &&
        exists(/databases/$(database)/documents/gyms/$(gymId)/memberEmails/$(authEmailKey())) &&
        (!('status' in get(/databases/$(database)/documents/gyms/$(gymId)/memberEmails/$(authEmailKey())).data) ||
          get(/databases/$(database)/documents/gyms/$(gymId)/memberEmails/$(authEmailKey())).data.status == 'active');
    }

    function inviteRole(gymId) {
      return get(/databases/$(database)/documents/gyms/$(gymId)/memberEmails/$(authEmailKey())).data.role;
    }

    function roleMatchesInvite(gymId, role) {
      return isInvitedToGym(gymId) &&
        (!('role' in get(/databases/$(database)/documents/gyms/$(gymId)/memberEmails/$(authEmailKey())).data) ||
          inviteRole(gymId) == role);
    }

    function isSameGym(gymId) {
      return signedIn() && gymId is string && gymId == currentUserGymId();
    }

    function canCreateInOwnGym(gymId) {
      return signedIn() &&
        gymId is string &&
        gymId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gymId;
    }

    // Read + lightweight write (notifications, metrics, payments) — includes coach.
    function canManageGym() {
      return signedIn() &&
        (currentUserRole() == 'owner' ||
         currentUserRole() == 'admin' ||
         currentUserRole() == 'coach' ||
         currentUserRole() == 'SuperAdmin');
    }

    // Sensitive write operations (gym settings, plans, expenses, invite list,
    // member management) — coach excluded intentionally.
    function canAdminGym() {
      return signedIn() &&
        (currentUserRole() == 'owner' ||
         currentUserRole() == 'admin' ||
         currentUserRole() == 'SuperAdmin');
    }

    function isSuperAdmin() {
      // Primary: custom claim (set via setup_admin.js — most secure)
      // Fallback: Firestore role field (works before custom claim is configured)
      return (request.auth != null && request.auth.token.superAdmin == true) ||
             (signedIn() && currentUser().role == 'SuperAdmin') ||
             (signedIn() && currentUser().role == 'super_admin');
    }

    function userGymId(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.gymId;
    }

    function userGymIdAfter(userId) {
      return getAfter(/databases/$(database)/documents/users/$(userId)).data.gymId;
    }

    match /foods/{foodId} {
      allow read: if true;
      allow write: if canManageGym();
    }

    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if canManageGym();
    }

    match /diet_templates/{templateId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /accountRecovery/{phoneKey} {
      // Only coaches/admins doing player management need this (phone-uniqueness
      // checks) — NOT every signed-in user, which would let anyone (including a
      // caller who just authenticated via the phone-recovery OTP flow) look up
      // which email/uid is linked to an arbitrary phone number.
      allow read: if canManageGym();
      allow write: if canManageGym();
    }

    // Gyms: the onboarding flow looks up a gym by gymCode BEFORE the user has
    // an account or a session at all, so get/list truly must stay public here.
    // Firestore rules cannot hide individual fields within a public document,
    // so nothing sensitive may ever be written onto this top-level doc — see
    // the /private subcollection below for the owner's email and any other
    // owner PII. Sensitive sub-collections (memberEmails, members) have their
    // own rules.
    match /gyms/{gymId} {
      // Public read: needed so the onboarding screen can look up a gym by gymCode
      // before the user creates an account. Only non-sensitive fields are exposed.
      allow get:  if true;
      allow list: if true;
      allow read, write: if isSuperAdmin();
      // Only owner / admin can edit gym settings — coach excluded.
      allow write: if canAdminGym() && gymId == currentUserGymId();

      // Owner PII (email, etc.) — NEVER put these on the parent /gyms doc,
      // which is publicly listable above. Super admin only; nothing in the
      // app currently reads this back, it exists for support/audit purposes.
      match /private/{docId} {
        allow read, write: if isSuperAdmin();
      }

      // Private allow-list: an email must exist here before it can join this gym.
      // Doc id is the normalized email, for example player@example.com.
      match /memberEmails/{email} {
        allow read: if hasVerifiedEmail() && email == authEmailKey();
        // Coaches can read the invite list but cannot add/remove invites.
        allow read: if canManageGym() && gymId == currentUserGymId();
        // Coaches can update existing member email records (name, phone, etc.)
        // but cannot create or delete entries (that stays admin-only).
        allow update: if canManageGym() && gymId == currentUserGymId();
        allow write: if canAdminGym() && gymId == currentUserGymId();
      }

      // Broadcast notifications sent by the gym admin — history log.
      match /admin_notifications/{notifId} {
        allow read, write: if isSuperAdmin();
        allow read: if canManageGym() && gymId == currentUserGymId();
        // Only admins/owners broadcast to all members — coach excluded.
        allow write: if canAdminGym() && gymId == currentUserGymId();
      }

      // Messages sent from Super Admin to this gym owner.
      match /super_admin_messages/{msgId} {
        allow read, write: if isSuperAdmin();
        allow read, update: if canAdminGym() && gymId == currentUserGymId();
      }

      // Import history — admin/owner only.
      match /importHistory/{entryId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if canAdminGym() && gymId == currentUserGymId();
      }

      // Commission invoices for this gym — admin/coach can read.
      match /commissionInvoices/{invoiceId} {
        allow read, write: if isSuperAdmin();
        allow read: if canManageGym() && gymId == currentUserGymId();
      }

      // Check-in records — coaches can check members in/out.
      match /checkins/{checkinId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if canManageGym() && gymId == currentUserGymId();
      }

      // Subscription plans — only admin/owner can create or modify plans.
      match /subscriptionPlans/{planId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && gymId == currentUserGymId();
        allow write: if canAdminGym() && gymId == currentUserGymId();
      }

      // Alias: Dart code writes to /plans (same semantics as subscriptionPlans).
      match /plans/{planId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && gymId == currentUserGymId();
        allow write: if canAdminGym() && gymId == currentUserGymId();
      }

      // Actual linked gym members. A user can create their own member link only
      // after email verification and only if their email is invited to this gym.
      match /members/{userId} {
        allow read: if isSameGym(gymId);
        allow create, update: if signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.gymId == gymId &&
          request.resource.data.email == authEmailKey() &&
          roleMatchesInvite(gymId, request.resource.data.role);
        // Coaches can update existing player member records (profile, subscription).
        // Cannot create or delete member entries — that remains admin-only.
        allow update: if canManageGym() &&
          gymId == currentUserGymId() &&
          resource.data.role == 'player';
        // Only admin/owner can manage member records (suspend, role change, etc.)
        allow write: if canAdminGym() && gymId == currentUserGymId();
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // /users/{userId}
    //
    // Role matrix:
    //   Super Admin  → full read/write/delete on ALL users globally
    //   Owner/Admin  → full read/write/delete on coaches + players in their gym
    //   Coach        → full read/write on players in their gym only
    //                  (cannot touch other coaches or admin/owner docs)
    //   Player       → own profile only + assigned coach's profile (read) + chat
    // ═══════════════════════════════════════════════════════════════════════════
    match /users/{userId} {

      // ── 1. Super Admin ──────────────────────────────────────────────────────
      allow read, write, delete: if isSuperAdmin();

      // ── 2. Own profile ──────────────────────────────────────────────────────
      allow read: if signedIn() && request.auth.uid == userId;

      // Self-registration on sign-up (email verified + gym invite check).
      //
      // SECURITY: the no-gymId branch below is the ONLY way to self-register
      // without an invite record, and it is hard-locked to role == 'player'.
      // Never widen this to allow any other role through the no-gymId path —
      // doing so previously let anyone create their own /users/{uid} doc with
      // role: 'SuperAdmin' (or 'admin'/'owner'/'coach') by simply omitting
      // gymId, since roleMatchesInvite() was skipped entirely in that case.
      allow create: if signedIn() &&
        request.auth.uid == userId &&
        hasVerifiedEmail() &&
        request.resource.data.email.lower() == authEmailKey() &&
        (
          (!('gymId' in request.resource.data) &&
            request.resource.data.role == 'player') ||
          ('gymId' in request.resource.data &&
            roleMatchesInvite(request.resource.data.gymId, request.resource.data.role))
        );

      // Super Admin bootstrap account (one-time).
      allow create: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.email == 'superadmin.nexus@gmail.com' &&
        request.resource.data.role == 'SuperAdmin';

      // User edits their own profile — cannot change role, gym, or email.
      allow update: if signedIn() &&
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['gymId', 'role', 'emailVerified', 'email']);

      // User updates gym/role when joining a new gym via invite.
      allow update: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.emailVerified == resource.data.emailVerified &&
        roleMatchesInvite(request.resource.data.gymId, request.resource.data.role);

      // ── 3. Owner / Admin — full control over their gym ──────────────────────
      // Read coaches, players, admins in their gym.
      allow read: if canAdminGym() && isSameGym(resource.data.gymId);

      // Create player or coach accounts.
      allow create: if canAdminGym() &&
        request.resource.data.role in ['player', 'coach'] &&
        request.resource.data.gymId == currentUserGymId();

      // Full update (subscription, role, status, everything).
      allow update: if canAdminGym() &&
        isSameGym(resource.data.gymId) &&
        request.resource.data.gymId == resource.data.gymId;

      // Delete any member of their gym.
      allow delete: if canAdminGym() && isSameGym(resource.data.gymId);

      // ── 4. Coach — full access to players in their gym ──────────────────────
      // Coach can read all users in their gym (players + other coaches visible).
      allow read: if canManageGym() && isSameGym(resource.data.gymId);

      // Coach has full write access on player documents only.
      allow create: if canManageGym() &&
        request.resource.data.role == 'player' &&
        request.resource.data.gymId == currentUserGymId();

      allow update: if canManageGym() &&
        isSameGym(resource.data.gymId) &&
        resource.data.role == 'player' &&
        request.resource.data.gymId == resource.data.gymId;

      allow delete: if canManageGym() &&
        isSameGym(resource.data.gymId) &&
        resource.data.role == 'player';

      // ── 5. Player reads their assigned coach's profile ──────────────────────
      allow read: if signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedCoachUid == userId;

      // ── Sub-collections ─────────────────────────────────────────────────────

      match /metrics/{metricId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        // Coach & admin: full access to player metrics.
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /daily_nutrition/{dateStr} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /progressPhotos/{photoId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        // Coach can view and manage player progress photos.
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /workoutHistory/{sessionId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /routines/{routineId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /exerciseHistory/{historyId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /appData/{documentId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /notifications/{notificationId} {
        allow read, write: if isSuperAdmin();
        allow read, update, delete: if signedIn() && request.auth.uid == userId;
        // Coach/admin sends notifications — rate-limited to 1 per 5 s per player.
        allow create: if canManageGym() &&
          userGymId(userId) == currentUserGymId() &&
          request.resource.data.senderId == request.auth.uid &&
          notifCooldownPassed(userId, 5) &&
          withinSizeLimit(2000);
        allow create: if chatNotificationAllowed(userId) && withinSizeLimit(2000);
        // Player requests a new nutrition plan — sends notification to their assigned coach.
        allow create: if signedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.type == 'nutrition_plan_request' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedCoachUid == userId &&
          withinSizeLimit(1000);
      }

      match /trophyAwards/{awardId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      // Payments — player can read their own; coach/admin can read + write.
      match /payments/{paymentId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() &&
          (userGymId(userId) == currentUserGymId() ||
           userGymIdAfter(userId) == currentUserGymId());
      }

      // Workout templates — private to the user only.
      match /templates/{templateId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // AI pose / form feedback — private to the user only.
      match /exercise_feedback/{feedbackId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // Commission invoices — user sees their own; admin/coach in same gym can read.
      match /commissionInvoices/{invoiceId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && request.auth.uid == userId;
        allow read: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      // Credit transaction history — private to the user.
      match /creditHistory/{entryId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && request.auth.uid == userId;
        allow read: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      // Coach nutrition plan — coach writes, player reads.
      match /coachNutritionPlan/{docId} {
        allow read, write: if isSuperAdmin();
        allow read: if signedIn() && request.auth.uid == userId;
        allow read, write: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      // Supplements — private to the user; coach/admin can read.
      match /supplements_routine/{docId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read: if canManageGym() && userGymId(userId) == currentUserGymId();
      }

      match /supplements_history/{docId} {
        allow read, write: if isSuperAdmin();
        allow read, write: if signedIn() && request.auth.uid == userId;
        allow read: if canManageGym() && userGymId(userId) == currentUserGymId();
      }
    }

    // Login brute-force counters — written only by the checkLoginLock /
    // recordLoginResult Cloud Functions via the Admin SDK, which bypasses
    // security rules entirely. No client (signed in or not) may read or
    // write this collection directly — not even Super Admin, since exposing
    // it client-side would let an attacker probe/clear their own lockout.
    match /loginAttempts/{email} {
      allow read, write: if false;
    }

    match /communityPosts/{postId} {
      allow read, write: if isSuperAdmin();
      allow read: if isSameGym(resource.data.gymId);
      // Rate-limited: max 1 post per 60 seconds per user.
      // Client must update users/{uid}.lastPostAt = serverTimestamp() atomically.
      allow create: if canCreateInOwnGym(request.resource.data.gymId) &&
        request.resource.data.userId == request.auth.uid &&
        postCooldownPassed(request.auth.uid, 60) &&   // 1 post / 60 s
        withinSizeLimit(10000);                        // max ~10 KB per post
      allow update: if isSameGym(resource.data.gymId) &&
        request.resource.data.gymId == resource.data.gymId &&
        (
          (
            resource.data.userId == request.auth.uid &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['gymId', 'userId', 'createdAt'])
          ) ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likesCount', 'commentsCount'])
        );
      allow delete: if isSameGym(resource.data.gymId) &&
        (resource.data.userId == request.auth.uid || canManageGym());

      match /comments/{commentId} {
        allow read, write: if isSuperAdmin();
        allow read: if isSameGym(resource.data.gymId);
        allow create: if canCreateInOwnGym(request.resource.data.gymId) &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSameGym(resource.data.gymId) &&
          (resource.data.userId == request.auth.uid || canManageGym());
      }
    }

    match /challenges/{challengeId} {
      allow read, write: if isSuperAdmin();
      allow read: if isSameGym(resource.data.gymId);
      allow create: if canManageGym() &&
        canCreateInOwnGym(request.resource.data.gymId) &&
        request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if canManageGym() && isSameGym(resource.data.gymId);
    }

    // Global commission invoices — Super Admin reads all; written by Cloud Functions only.
    match /commissionInvoices/{invoiceId} {
      allow read, write: if isSuperAdmin();
    }

    // collectionGroup query across all gyms' super_admin_messages — Super Admin only.
    match /{path=**}/super_admin_messages/{msgId} {
      allow read, write: if isSuperAdmin();
    }

    match /{path=**}/payments/{paymentId} {
      allow read, write: if isSuperAdmin();
      // Allow gym admins/owners to read their own gym's payments via
      // collectionGroup query — the payment doc must carry gymId for this rule
      // to fire. Payments without gymId (legacy) are invisible to this rule
      // and still accessible via the /users/{uid}/payments/{id} path above.
      allow read: if canManageGym() &&
        resource.data.gymId is string &&
        resource.data.gymId == currentUserGymId();
    }

    match /chats/{chatId} {
      allow read, write: if isSuperAdmin();
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() &&
        (
          request.auth.uid in resource.data.participants ||
          request.auth.uid in request.resource.data.participants
        );

      match /messages/{messageId} {
        allow read, write: if isSuperAdmin();
        // Only participants of the parent chat room can read messages.
        allow read: if chatParticipant(chatId);

        // Sender must be a participant, must be the author, AND must not exceed
        // 1 message per second (rate-limited via chatDoc.lastMessageAt).
        allow create: if signedIn() &&
          request.auth.uid == request.resource.data.senderId &&
          chatParticipantAfter(chatId) &&
          chatMessageAllowed(chatId, 1) &&
          withinSizeLimit(5000);

        // Messages are immutable once sent.
        allow update, delete: if false;
      }
    }

    // Gym-scoped collections — any document that carries a gymId field is
    // restricted to members of that gym only. Explicit collection rules above
    // take precedence over this wildcard; this acts as a safe default for any
    // future collections (workouts, sessions, plans, etc.) that store gymId.
    // If a collection should NOT be gym-scoped, add an explicit rule above.
    match /coachNotifications/{notificationId} {
      allow read, write: if isSuperAdmin();
      allow read: if canManageGym() &&
        resource.data.senderId == request.auth.uid;
      allow create: if canManageGym() &&
        canCreateInOwnGym(request.resource.data.gymId) &&
        request.resource.data.senderId == request.auth.uid;
    }

    match /{collection}/{document} {
      allow read, write: if isSuperAdmin();
      allow read, update, delete: if
        !(collection in ['communityPosts', 'challenges', 'coachNotifications']) &&
        isSameGym(resource.data.gymId);
      allow create: if
        !(collection in ['communityPosts', 'challenges', 'coachNotifications']) &&
        isSameGym(request.resource.data.gymId);
    }

    // Nested gym-scoped documents (e.g. workouts/{id}/sets/{setId}).
    match /{collection}/{document}/{rest=**} {
      allow read, write: if isSuperAdmin();
      allow read, update, delete: if
        !(collection in ['communityPosts', 'challenges', 'coachNotifications']) &&
        isSameGym(resource.data.gymId);
      allow create: if
        !(collection in ['communityPosts', 'challenges', 'coachNotifications']) &&
        isSameGym(request.resource.data.gymId);
    }
  }
}
